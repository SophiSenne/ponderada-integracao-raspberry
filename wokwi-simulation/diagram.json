{
  "version": 1,
  "author": "Sophia Silva",
  "editor": "wokwi",
  "parts": [
    {
      "type": "board-pi-pico-w",
      "id": "pico",
      "top": 0,
      "left": 0,
      "attrs": {}
    },
    {
      "type": "wokwi-ntc-temperature-sensor",
      "id": "ntc1",
      "top": 50,
      "left": -180,
      "attrs": {}
    }
  ],
  "connections": [
    [ "ntc1:VCC", "pico:3V3",    "red",   [] ],
    [ "ntc1:GND", "pico:GND",    "black", [] ],
    [ "ntc1:OUT", "pico:GP26",   "green", [] ],
    [ "pico:GP0", "$serialMonitor:RX", "", [] ],
    [ "pico:GP1", "$serialMonitor:TX", "", [] ]
  ],
  "serialMonitor": { "collapse": false, "display": "always" },
  "dependencies": {}
}